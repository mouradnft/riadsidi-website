# ─────────────────────────────────────────────────────────────
# SANITY CMS — get these from https://sanity.io/manage
# after creating your project
# ─────────────────────────────────────────────────────────────

# Your Sanity project ID (visible in sanity.io/manage → project settings)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here

# Always "production" for the live site
NEXT_PUBLIC_SANITY_DATASET=production

# Secret API token — go to sanity.io/manage → API → Tokens → Add token
# Give it "Viewer" permissions for the frontend
SANITY_API_TOKEN=your_secret_token_here

# ─────────────────────────────────────────────────────────────
# CONTACT FORM — get this from https://resend.com
# Resend is the service that sends emails when someone fills the form
# ─────────────────────────────────────────────────────────────

# Your Resend API key
RESEND_API_KEY=re_your_key_here

# The email address where contact form submissions will be sent
CONTACT_EMAIL=info@riadsidi.com

# ─────────────────────────────────────────────────────────────
# SANITY WEBHOOK — for live content updates
# This is a random secret string you create yourself (any random text)
# Set the SAME value in Sanity dashboard → API → Webhooks
# ─────────────────────────────────────────────────────────────
SANITY_REVALIDATE_SECRET=any_random_secret_string_here
